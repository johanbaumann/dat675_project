{
  "training_preset": "custom",
  "data": {
    "prop_file": "smiles_prop.txt",
    "seq_length": 120,
    "train_ratio": 0.75
  },
  "model": {
    "mode": "transformer",
    "latent_size": 32,
    "unit_size": 64,
    "n_rnn_layer": 1,
    "num_prop": 3,
    "mean": 0.0,
    "stddev": 1.0
  },
  "transformer": {
    "heads": 8,
    "ff_size": 128,
    "dropout": 0.1
  },
  "optimization": {
    "optimizer": "adamw",
    "lr": 0.0001,
    "weight_decay": 0.0,
    "use_amp": true,
    "amp_dtype": "float16",
    "grad_clip_norm": 8.0
  },
  "training": {
    "batch_size": 32,
    "num_epochs": 1,
    "save_dir": "save/smoke_cfg_transformer_fix",
    "save_every": 1,
    "early_stopping_patience": 10,
    "early_stopping_min_delta": 0.0,
    "early_stopping_restore_best": true
  },
  "scheduler": {
    "enabled": false,
    "factor": 0.5,
    "patience": 10,
    "threshold": 0.0001,
    "min_lr": 0.000001
  },
  "kl": {
    "enabled": true,
    "start_beta": 0.01,
    "max_beta": 1.0,
    "hold_epochs": 0,
    "warmup_epochs": 50
  },
  "diagnostics": {
    "every": 1
  }
}
